{
  "name": "game-app",
  "private": true,
  "version": "1.2.95",
  "type": "module",
  "scripts": {
    "dev": "vite --host --open",
    "build": "node ./node_modules/typescript-7/bin/tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:licenses": "license-compliance --direct --allow 'MIT;ISC;0BSD;BSD-2-Clause;BSD-3-Clause;Apache-2.0;Unlicense;CC0-1.0'",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.reportOnFailure",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=coverage/junit.xml",
    "test:e2e": "mkdir -p cypress/results && start-server-and-test dev http://localhost:5173 'cypress run --reporter cypress-multi-reporters --reporter-options configFile=cypress.config.reporter.json'",
    "test:e2e:ci": "mkdir -p cypress/results && start-server-and-test dev http://localhost:5173 'cypress run --headless --reporter cypress-multi-reporters --reporter-options configFile=cypress.config.reporter.json'",
    "docs:api": "typedoc"
  },
  "engines": {
    "node": ">=26"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "src/**/*.d.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/test/",
    "public/",
    "index.html",
    "tsconfig.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "vite.config.ts",
    "README.md"
  ],
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "howler": "2.2.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/howler": "2.2.13",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "cypress": "15.18.1",
    "cypress-junit-reporter": "1.3.1",
    "cypress-multi-reporters": "2.0.5",
    "eslint": "10.6.0",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "license-compliance": "3.0.1",
    "start-server-and-test": "3.0.11",
    "typedoc": "0.28.20",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-7": "npm:typescript@7.0.1-rc",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.5",
    "brace-expansion": "5.0.7",
    "joi": "17.13.4"
  }
}
